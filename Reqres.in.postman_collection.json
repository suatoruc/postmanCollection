							"pm.environment.set(\"email\", email);\r",
							"pm.environment.set(\"first_name\", firstName);\r",
							"pm.environment.set(\"last_name\", lastName);\r",
							"pm.test(\"Status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
